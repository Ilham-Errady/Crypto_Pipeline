      <aliases enabled='yes' />
      <column caption='Crypto Id' datatype='string' name='[CRYPTO_ID]' role='dimension' type='nominal' />
      <column caption='Crypto Key (Dim Crypto)' datatype='integer' name='[CRYPTO_KEY (DIM_CRYPTO)]' role='dimension' type='ordinal' />
      <column caption='Crypto Key' datatype='integer' name='[CRYPTO_KEY]' role='dimension' type='ordinal' />
      <column caption='Variation Prix 7J' datatype='real' name='[Calculation_1296337406099456]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([PRICE_USD]) - LOOKUP(SUM([PRICE_USD]), -7)) / LOOKUP(SUM([PRICE_USD]), -7)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Ratio Volume / Market Cap' datatype='real' name='[Calculation_1296337474838529]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([TOTAL_VOLUME_USD]) / SUM([MARKET_CAP_USD])' />
      </column>
      <column caption='Performance Relative' datatype='real' name='[Calculation_1296337475596290]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([PRICE_USD]) - WINDOW_MIN(SUM([PRICE_USD]))) / WINDOW_MIN(SUM([PRICE_USD]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Métrique Dynamique' datatype='real' name='[Calculation_1296337478762500]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [Parameters].[Paramètre 1296337477849091]&#13;&#10;  WHEN &quot;Prix&quot; THEN SUM([PRICE_USD])&#13;&#10;  WHEN &quot;Volume&quot; THEN SUM([TOTAL_VOLUME_USD])&#13;&#10;  WHEN &quot;Market Cap&quot; THEN SUM([MARKET_CAP_USD])&#13;&#10;END' />
      </column>
